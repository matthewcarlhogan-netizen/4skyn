# Copy to .env and chmod 600. NEVER commit .env to git.

# Bybit testnet — trade orders
BYBIT_TESTNET_API_KEY=
BYBIT_TESTNET_API_SECRET=

# Bybit mainnet — market data only (read-only key recommended)
BYBIT_MAINNET_API_KEY=
BYBIT_MAINNET_API_SECRET=

# When you go live, create a SECOND mainnet key scoped to "Contract Trade"
# ONLY. No withdraw permission. IP-whitelist it to your VPS IP.
BYBIT_LIVE_API_KEY=
BYBIT_LIVE_API_SECRET=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Mode: "testnet" | "live"
TRADING_MODE=testnet
